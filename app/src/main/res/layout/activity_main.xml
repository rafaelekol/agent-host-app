<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Claude Auth JSON"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/authJsonInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|start"
            android:hint="Paste your Claude Auth JSON here"
            android:inputType="textMultiLine"
            android:minLines="8"
            android:scrollbars="vertical"
            android:textIsSelectable="true"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/saveAuthButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Save Auth" />

        <Button
            android:id="@+id/requestNotificationsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Request Notification Permission" />

        <Button
            android:id="@+id/requestBatteryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ignore Battery Optimizations" />

        <Button
            android:id="@+id/autostartButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Enable Autostart (MIUI/ColorOS/etc.)"
            android:visibility="gone" />

        <Button
            android:id="@+id/startServiceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Start Agent Service" />

    </LinearLayout>

</ScrollView>
